        },
        "question_xcwxzU": {
          "type": "question",
          "settings": {
            "question": "<strong>How long before I see results?</strong>",
            "answer": "<p>Most users notice improvements in hydration, clarity, and texture within 2\u20134 weeks. More significant changes typically occur over a full 8\u201312 week skin cycle.</p>"
