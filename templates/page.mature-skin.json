        "question_wbie3a": {
          "type": "question",
          "settings": {
            "question": "1. Is this suitable for very sensitive or reactive skin?",
            "answer": "<p>Yes. The protocol was designed specifically for thinning, fragile and reactive skin after 45. The focus is restoring barrier integrity before introducing active ingredients.</p>"
