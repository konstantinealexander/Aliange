{% comment %}
  Aliangé PDP Final CTA Section
  Full-width closing CTA banner.
{% endcomment %}

{%- style -%}
  #pdp-cta-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: var(--pdp-space-3xl) var(--pdp-space-md);
    text-align: center;
  }

  #pdp-cta-{{ section.id }} .cta-container {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--pdp-space-lg);
  }

  #pdp-cta-{{ section.id }} .cta-heading {
    font-family: var(--pdp-font-heading);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 600;
    color: var(--pdp-ink);
    line-height: 1.2;
    margin: 0;
    text-wrap: balance;
  }

  #pdp-cta-{{ section.id }} .cta-heading .pdp-accent {
    font-family: var(--pdp-font-accent);
    font-weight: 400;
    font-style: italic;
  }

  #pdp-cta-{{ section.id }} .cta-subheading {
    font-family: var(--pdp-font-body);
    font-size: clamp(14px, 1.5vw, 17px);
    color: var(--pdp-body);
    line-height: 1.65;
    margin: 0;
    max-width: 560px;
  }

  #pdp-cta-{{ section.id }} .cta-trust {
    font-family: var(--pdp-font-body);
    font-size: 12px;
    font-weight: 500;
    color: var(--pdp-body);
    letter-spacing: 0.02em;
    margin: 0;
  }

  #pdp-cta-{{ section.id }} .cta-secondary-link {
    font-family: var(--pdp-font-body);
    font-size: 14px;
    color: var(--pdp-accent, #1a1a2e);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s ease;
  }
  #pdp-cta-{{ section.id }} .cta-secondary-link:hover { opacity: 0.7; }
{%- endstyle -%}

<section id="pdp-cta-{{ section.id }}" class="pdp-reveal" aria-label="Final call to action">
  <div class="cta-container">
    {% if section.settings.heading != blank %}
      <h2 class="cta-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="cta-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_url | default: '#' }}" class="pdp-btn pdp-btn--primary">
        <span>{{ section.settings.button_text }}</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"/></svg>
      </a>
    {% endif %}

    {% if section.settings.trust_line != blank %}
      <p class="cta-trust">{{ section.settings.trust_line }}</p>
    {% endif %}

    {% if section.settings.secondary_link_text != blank and section.settings.secondary_link_url != blank %}
      <a href="{{ section.settings.secondary_link_url }}" class="cta-secondary-link">{{ section.settings.secondary_link_text }}</a>
    {% endif %}
  </div>
</section>

{% render 'aliange-pdp-scripts' %}

{% schema %}
{
  "name": "PDP Final CTA",
  "tag": "section",
  "class": "aliange-pdp-final-cta",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Future Skin Will Thank You"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Invest in clinically proven protection today and enjoy a firmer, smoother, more youthful complexion."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Protect My Skin Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "trust_line",
      "label": "Trust line",
      "default": "90-Day Results Guarantee Or Your Money Back"
    },
    {
      "type": "text",
      "id": "secondary_link_text",
      "label": "Secondary link text",
      "info": "E.g. 'Learn about our clinical approach to ageing →'"
    },
    {
      "type": "url",
      "id": "secondary_link_url",
      "label": "Secondary link URL",
      "info": "Link to a pillar or concern page for SEO internal linking"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F4F7F9"
    }
  ],
  "presets": [
    {
      "name": "PDP Final CTA"
    }
  ]
}
{% endschema %}
