
{%- style -%}
  #proto-synergy-{{ section.id }} { background-color: var(--lp-bg); }
  #proto-synergy-{{ section.id }} .proto-synergy-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--lp-space-xl);
  }
  #proto-synergy-{{ section.id }} .proto-synergy-intro {
    font-family: var(--lp-font-body);
    font-size: 15px;
    color: var(--lp-body);
    line-height: 1.7;
    {% if section.settings.image == blank %}
    max-width: 720px;
    margin: 0 auto var(--lp-space-2xl);
    text-align: center;
    {% else %}
    margin-bottom: var(--lp-space-xl);
    {% endif %}
  }
  #proto-synergy-{{ section.id }} .proto-synergy-grid {
    display: flex;
    flex-direction: column;
    gap: var(--lp-space-md);
    {% if section.settings.image == blank %}
    max-width: var(--lp-container-sm);
    margin: 0 auto;
    {% endif %}
  }
  {% if section.settings.image %}
  #proto-synergy-{{ section.id }} .proto-synergy-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--lp-space-2xl);
    align-items: start;
  }
  @media (min-width: 768px) {
    #proto-synergy-{{ section.id }} .proto-synergy-body { grid-template-columns: 1fr 1fr; }
    {% if section.settings.image_position == 'left' %}
    #proto-synergy-{{ section.id }} .proto-synergy-body-image { order: -1; }
    {% else %}
    #proto-synergy-{{ section.id }} .proto-synergy-body-image { order: 1; }
    {% endif %}
  }
  #proto-synergy-{{ section.id }} .proto-synergy-body-image {
    border-radius: var(--lp-radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }
  #proto-synergy-{{ section.id }} .proto-synergy-body-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  {% endif %}
  #proto-synergy-{{ section.id }} .proto-synergy-card {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--lp-space-lg);
    align-items: start;
    background-color: var(--lp-bg-muted);
    border: 1px solid var(--lp-border);
    border-radius: var(--lp-radius-lg);
    padding: var(--lp-space-xl);
  }
  #proto-synergy-{{ section.id }} .proto-synergy-num {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: var(--lp-ink);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--lp-font-heading);
    font-size: 14px;
    font-weight: 600;
    flex-shrink: 0;
    letter-spacing: 0.05em;
  }
  #proto-synergy-{{ section.id }} .proto-synergy-title {
    font-family: var(--lp-font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--lp-ink);
    margin: 0 0 4px;
  }
  #proto-synergy-{{ section.id }} .proto-synergy-desc {
    font-family: var(--lp-font-body);
    font-size: 14px;
    color: var(--lp-body);
    line-height: 1.65;
    margin: 0;
  }
{%- endstyle -%}

<section id="proto-synergy-{{ section.id }}" class="lp-section">
  <div class="lp-container">
    <div class="proto-synergy-header lp-reveal">
      {%- if section.settings.label != blank -%}
        <span class="lp-section-label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="lp-heading-lg">{{ section.settings.headline }}</h2>
    </div>

    <div class="proto-synergy-body">
      {%- if section.settings.image -%}
        <div class="proto-synergy-body-image lp-reveal">
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.image.alt | default: section.settings.headline | escape }}"
            width="900"
            height="{{ 900 | divided_by: section.settings.image.aspect_ratio | round }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}

      <div>
        {%- if section.settings.body != blank -%}
          <p class="proto-synergy-intro lp-reveal">{{ section.settings.body }}</p>
        {%- endif -%}

        <div class="proto-synergy-grid">
          {%- for block in section.blocks -%}
            <div class="proto-synergy-card lp-reveal" {{ block.shopify_attributes }}>
              <div class="proto-synergy-num" aria-hidden="true">0{{ forloop.index }}</div>
              <div>
                <h3 class="proto-synergy-title">{{ block.settings.title }}</h3>
                <p class="proto-synergy-desc">{{ block.settings.description }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% render 'aliange-lp-scripts' %}

{% schema %}
{
  "name": "Protocol - Synergy",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow label", "default": "The Science" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Engineered to Work as One System" },
    { "type": "textarea", "id": "body", "label": "Body text", "default": "Each step enhances the efficacy of the next, guiding skin from congestion to clarity." },
    { "type": "image_picker", "id": "image", "label": "Optional image" },
    { "type": "select", "id": "image_position", "label": "Image position", "options": [{"value":"right","label":"Right"},{"value":"left","label":"Left"}], "default": "right" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Synergy Point",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Prepare & Decongest" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "The Cleanser and Exfoliator purify skin and clear pores for treatment products." }
      ]
    }
  ],
  "presets": [{ "name": "Protocol - Synergy" }]
}
{% endschema %}
