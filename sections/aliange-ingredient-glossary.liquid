<script>
(function() {
  const ING_DATA = [
    { name:"Acetyl Hexapeptide-51 Amide", inci:"Acetyl Hexapeptide-51 Amide", cat:"peptide", catLabel:"Peptide", catClass:"ing-cat-peptide", desc:"A synthetic peptide inspired by the extraordinary DNA-repair mechanisms of the jellyfish. It activates the skin's own nucleotide excision repair (NER) system, helping to reverse accumulated UV-induced DNA damage that drives premature ageing.", products:["Jellyfish Peptide X Serum"] },
    { name:"Acer Saccharum (Sugar Maple) Extract", inci:"Acer Saccharum Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"Derived from the sugar maple tree, this natural AHA-bearing extract helps to gently accelerate cell turnover, refine skin texture, and brighten the complexion by dissolving the bonds between dead surface cells.", products:["Revitalize Brightening Serum","Transforming Exfoliator"] },
    { name:"Albizia Julibrissin Bark Extract", inci:"Albizia Julibrissin Bark Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"Sourced from the Persian Silk Tree, this extract is clinically studied for its ability to combat glycation — the cross-linking of collagen fibres by sugar molecules that makes skin rigid and prone to wrinkling.", products:["Rejuvenating Eye Cream"] },
    { name:"Allantoin", inci:"Allantoin", cat:"hydrator", catLabel:"Soothing Agent", catClass:"ing-cat-hydrator", desc:"A naturally occurring compound found in comfrey root. It stimulates cell proliferation, accelerates skin renewal, and calms irritation — making it ideal for sensitive or compromised skin.", products:["Daily Devotion Cleanser"] },
    { name:"Alpha-Glucan Oligosaccharide", inci:"Alpha-Glucan Oligosaccharide", cat:"probiotic", catLabel:"Prebiotic", catClass:"ing-cat-probiotic", desc:"A prebiotic oligosaccharide that selectively feeds beneficial bacteria on the skin's surface. By nurturing the skin microbiome, it helps maintain microbial balance that supports barrier integrity and defends against harmful pathogens.", products:["Probiotic Radiance Masque"] },
    { name:"Ascorbic Acid", inci:"Ascorbic Acid", cat:"vitamin", catLabel:"Vitamin C", catClass:"ing-cat-vitamin", desc:"The purest, most potent form of Vitamin C. Inhibits melanin synthesis to fade discolouration, stimulates collagen production, and provides powerful antioxidant defence against UV- and pollution-generated free radicals.", products:["Revitalize Brightening Serum"] },
    { name:"Bentonite", inci:"Bentonite", cat:"mineral", catLabel:"Mineral Clay", catClass:"ing-cat-mineral", desc:"A naturally occurring volcanic clay with exceptional capacity to absorb oil and draw impurities from pores. In masque formulations, it delivers a deep-cleansing effect, refining pore appearance and leaving skin clarified.", products:["Probiotic Radiance Masque"] },
    { name:"Bisabolol", inci:"Bisabolol", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"A naturally derived terpene alcohol found in German chamomile. It reduces redness, soothes irritation, and enhances the skin's tolerance to active ingredients — a key inclusion in targeted treatment formulas.", products:["Biocinamide Serum"] },
    { name:"Butyl Methoxydibenzoylmethane", inci:"Butyl Methoxydibenzoylmethane", cat:"spf", catLabel:"UVA Filter", catClass:"ing-cat-spf", desc:"Known as Avobenzone, one of the most effective UVA absorbers available. Provides stable, broad-spectrum UVA protection covering the full range of long-wave UV radiation responsible for photoageing and DNA damage deep in the dermis.", products:["Revitalize Anti-Ageing Day Cream SPF 15"] },
    { name:"Butyrospermum Parkii (Shea) Butter", inci:"Butyrospermum Parkii Butter", cat:"oil", catLabel:"Emollient", catClass:"ing-cat-oil", desc:"Cold-pressed from the African shea tree, exceptionally high in fatty acids and vitamin F. Deeply nourishes and reinforces the skin's lipid barrier, preventing moisture loss and leaving skin supple.", products:["Jellyfish Peptide X Serum","Rejuvenating Eye Cream"] },
    { name:"Camellia Sinensis (Green Tea) Leaf Extract", inci:"Camellia Sinensis Leaf Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"Rich in catechin polyphenols (particularly EGCG), green tea extract provides potent antioxidant and anti-inflammatory protection. It neutralises free radicals, calms sensitised skin, and has demonstrated photoprotective properties.", products:["Transforming Exfoliator"] },
    { name:"Carica Papaya Fruit Extract", inci:"Carica Papaya Fruit Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"A natural source of papain, a proteolytic enzyme that gently dissolves dead surface cells by breaking down the keratin proteins that bind them. Delivers a smooth, brightened complexion without abrasion.", products:["Rejuvenating Eye Cream"] },
    { name:"Carthamus Tinctorius (Safflower) Oil", inci:"Carthamus Tinctorius Seed Oil", cat:"oil", catLabel:"Botanical Oil", catClass:"ing-cat-oil", desc:"A lightweight, non-comedogenic oil with one of the highest concentrations of linoleic acid (omega-6). Linoleic acid is critical for ceramide synthesis and maintaining a healthy skin barrier.", products:["Exosome Cream"] },
    { name:"Centella Asiatica Extract", inci:"Centella Asiatica Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"An ancient herb with formidable clinical evidence. Stimulates fibroblasts to boost collagen and HA production, accelerates wound healing, strengthens the barrier, and provides meaningful anti-inflammatory action.", products:["Revitalize Anti-Ageing Day Cream SPF 15"] },
    { name:"Cetylhydroxyproline Palmitamide", inci:"Cetylhydroxyproline Palmitamide", cat:"peptide", catLabel:"Lipopeptide", catClass:"ing-cat-peptide", desc:"A ceramide-analogue lipopeptide that mimics the skin's own barrier components. It enhances cohesion within the stratum corneum, strengthens the moisture seal, and improves tolerance to external stressors.", products:["Biocinamide Serum"] },
    { name:"Chamomilla Recutita (Matricaria) Flower Extract", inci:"Chamomilla Recutita Flower Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"German chamomile extract rich in apigenin and bisabolol. Delivers potent anti-inflammatory and skin-calming properties, relieves redness, and is gentle enough for even the most sensitive complexions.", products:["Transforming Exfoliator"] },
