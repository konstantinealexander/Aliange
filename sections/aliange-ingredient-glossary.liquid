    { name:"Cucumis Sativus (Cucumber) Fruit Extract", inci:"Cucumis Sativus Fruit Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"Contains caffeic acid and vitamin C delivering genuine anti-inflammatory and antioxidant action. Cools reactive skin, reduces puffiness, and provides a calming counterbalance to exfoliating acids.", products:["Transforming Exfoliator"] },
    { name:"Darutoside", inci:"Darutoside", cat:"botanical", catLabel:"Botanical Active", catClass:"ing-cat-botanical", desc:"A phytol diterpene glycoside from Sigesbeckia orientalis, clinically shown to significantly reduce the depth of wrinkle folds. Works by inhibiting matrix metalloproteinases (MMPs) that break down the skin's collagen network.", products:["Rejuvenating Eye Cream"] },
    { name:"Diethylamino Hydroxybenzoyl Hexyl Benzoate", inci:"Diethylamino Hydroxybenzoyl Hexyl Benzoate", cat:"spf", catLabel:"UVA Filter", catClass:"ing-cat-spf", desc:"Known as Uvinul A Plus, a next-generation photostable UVA filter providing stable, high-performance protection across the full UVA spectrum. Does not degrade in sunlight, ensuring consistent protection throughout the day.", products:["Revitalize Anti-Ageing Day Cream SPF 15"] },
    { name:"Disodium Adenosine Triphosphate", inci:"Disodium Adenosine Triphosphate", cat:"hydrator", catLabel:"Cell Energiser", catClass:"ing-cat-hydrator", desc:"ATP is the primary energy currency of every cell. As a topical active, it fuels cellular processes including barrier repair, protein synthesis, and collagen production — supplying skin cells with the energy they need to function at their best.", products:["Rejuvenating Eye Cream"] },
    { name:"Echinacea Angustifolia Leaf Extract", inci:"Echinacea Angustifolia Leaf Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"Delivers meaningful antioxidant and anti-inflammatory activity. Neutralises free radicals generated by UV exposure and supports the skin's own defence mechanisms against environmental stress.", products:["Revitalize Anti-Ageing Day Cream SPF 15"] },
    { name:"Endexome-EXO™", inci:"Endexome-EXO™ (Exosome Complex)", cat:"exosome", catLabel:"Exosome Technology", catClass:"ing-cat-exosome", desc:"The defining ingredient of the Aliangé range. Delivers over 4 billion stem cell-derived nano-vesicles per application, carrying a payload of growth factors, signalling proteins, and genetic material (mRNA/miRNA) that instruct skin cells to repair damage and increase collagen and elastin. In a 12-week histological study, treatment resulted in significant, measurable increases in dermal collagen and elastin.", products:["Exosome Cream"] },
    { name:"Glycerin", inci:"Glycerin", cat:"hydrator", catLabel:"Humectant", catClass:"ing-cat-hydrator", desc:"One of skincare's most validated ingredients, glycerin draws water from the environment and deeper skin layers into the stratum corneum. It also supports barrier function by filling the intercellular space between skin cells.", products:["Biocinamide Serum","Daily Devotion Cleanser","Jellyfish Peptide X Serum","Rejuvenating Eye Cream","Revitalize Anti-Ageing Day Cream SPF 15","Revitalize Brightening Serum","Revitalize Ultimate A Night Cream","Transforming Exfoliator","Probiotic Radiance Masque","Exosome Cream"] },
    { name:"Glycolic Acid", inci:"Glycolic Acid", cat:"acid", catLabel:"AHA", catClass:"ing-cat-acid", desc:"The gold standard alpha-hydroxy acid. With the smallest molecular size of all AHAs, it penetrates most effectively, dissolving the desmosomes holding dead cells together and accelerating cell turnover. Visibly improves texture, tone, and the appearance of fine lines.", products:["Revitalize Brightening Serum","Transforming Exfoliator"] },
    { name:"Glycyrrhiza Glabra (Licorice) Root Extract", inci:"Glycyrrhiza Glabra Root Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"A highly regarded brightening and anti-inflammatory botanical. Its key compound, glabridin, inhibits tyrosinase — the enzyme driving melanin production — without cytotoxicity, while also calming redness and post-inflammatory hyperpigmentation.", products:["Revitalize Brightening Serum"] },
    { name:"Hydrolyzed Adansonia Digitata Seed Protein", inci:"Hydrolyzed Adansonia Digitata Seed Protein", cat:"peptide", catLabel:"Plant Protein", catClass:"ing-cat-peptide", desc:"A hydrolysed protein from baobab seeds. The small peptide fragments formed during hydrolysis penetrate the skin's surface to strengthen the dermis, reduce expression lines, and provide a tightening, lifting effect.", products:["Rejuvenating Eye Cream"] },
    { name:"Hydrolyzed Quinoa", inci:"Hydrolyzed Quinoa", cat:"peptide", catLabel:"Plant Protein", catClass:"ing-cat-peptide", desc:"Delivers a rich array of amino acids directly to the skin. Reinforces the intercellular matrix, improves skin elasticity, and helps repair a compromised barrier — particularly valuable in the delicate eye area.", products:["Rejuvenating Eye Cream"] },
    { name:"Hydroxyphenyl Propamidobenzoic Acid", inci:"Hydroxyphenyl Propamidobenzoic Acid", cat:"hydrator", catLabel:"Soothing Active", catClass:"ing-cat-hydrator", desc:"A novel anti-inflammatory compound that calms reactive skin by inhibiting key mediators of the inflammatory cascade, particularly effective at reducing redness and sensitivity associated with UV exposure.", products:["Biocinamide Serum"] },
    { name:"Jojoba Esters", inci:"Jojoba Esters", cat:"oil", catLabel:"Emollient", catClass:"ing-cat-oil", desc:"Structurally unique waxy solids that closely mimic the skin's own sebum. Provide conditioning without greasiness, improve skin feel, and offer gentle physical exfoliation in rinse-off formulas.", products:["Daily Devotion Cleanser","Transforming Exfoliator"] },
    { name:"Kaolin", inci:"Kaolin", cat:"mineral", catLabel:"Mineral Clay", catClass:"ing-cat-mineral", desc:"The gentlest of all cosmetic clays. Absorbs excess sebum and draws out surface impurities without stripping natural oils. Leaves skin clarified and smooth — suitable even for dry or sensitive skin types.", products:["Probiotic Radiance Masque"] },
    { name:"Lactic Acid", inci:"Lactic Acid", cat:"acid", catLabel:"AHA", catClass:"ing-cat-acid", desc:"A naturally derived alpha-hydroxy acid with a distinguished dual function: as an exfoliant it dissolves dead skin cells, and as a humectant it simultaneously attracts water and supports the Natural Moisturising Factor — making it the gentlest and most hydrating of all AHAs.", products:["Jellyfish Peptide X Serum","Revitalize Brightening Serum","Transforming Exfoliator"] },
    { name:"Lactobacillus", inci:"Lactobacillus", cat:"probiotic", catLabel:"Probiotic", catClass:"ing-cat-probiotic", desc:"A genus of beneficial bacteria central to the skin and gut microbiome. As a topical active, lactobacillus derivatives reinforce the microbiome-mediated barrier, reduce inflammatory responses, and support healthy skin flora.", products:["Probiotic Radiance Masque"] },
    { name:"Lactococcus Ferment Lysate", inci:"Lactococcus Ferment Lysate", cat:"probiotic", catLabel:"Probiotic Ferment", catClass:"ing-cat-probiotic", desc:"A postbiotic — bioactive metabolites produced when lactic acid bacteria are fermented and lysed. Clinical studies show it enhances epidermal barrier function, modulates the skin's immune response, and supports recovery from UV damage.", products:["Biocinamide Serum","Probiotic Radiance Masque"] },
    { name:"Macadamia Ternifolia Seed Oil", inci:"Macadamia Ternifolia Seed Oil", cat:"oil", catLabel:"Botanical Oil", catClass:"ing-cat-oil", desc:"Native to Australia, macadamia oil contains one of the highest known concentrations of palmitoleic acid — an omega-7 fatty acid that naturally occurs in young, healthy skin but declines significantly with age.", products:["Jellyfish Peptide X Serum","Probiotic Radiance Masque"] },
    { name:"Malic Acid", inci:"Malic Acid", cat:"acid", catLabel:"AHA", catClass:"ing-cat-acid", desc:"A naturally occurring AHA found in apples and stone fruits. With a larger molecular structure than glycolic or lactic acid, it delivers gentler exfoliation suited to sensitive skin, working synergistically in multi-acid formulas.", products:["Revitalize Brightening Serum","Transforming Exfoliator"] },
    { name:"Melaleuca Alternifolia (Tea Tree) Leaf Oil", inci:"Melaleuca Alternifolia Leaf Oil", cat:"botanical", catLabel:"Essential Oil Active", catClass:"ing-cat-botanical", desc:"An Australian essential oil with well-documented antimicrobial, antifungal, and anti-inflammatory properties. Targets acne-causing bacteria (C. acnes) and controls sebum oxidation, making it a valuable active in clarifying formulations.", products:["Transforming Exfoliator"] },
    { name:"Niacinamide", inci:"Niacinamide", cat:"vitamin", catLabel:"Vitamin B3", catClass:"ing-cat-vitamin", desc:"One of the most extensively researched actives in modern dermatology. Simultaneously inhibits melanin transfer, strengthens the ceramide-rich barrier, reduces TEWL, minimises pore appearance, and controls sebum. Exceptionally well-tolerated and synergises with virtually all other actives.", products:["Biocinamide Serum","Rejuvenating Eye Cream"] },
    { name:"Octocrylene", inci:"Octocrylene", cat:"spf", catLabel:"UVB Filter", catClass:"ing-cat-spf", desc:"A synthetic UV filter providing broad UVB protection. Also acts as a photostabiliser for other UV filters (particularly Avobenzone), helping to maintain overall SPF efficacy throughout the day.", products:["Revitalize Anti-Ageing Day Cream SPF 15"] },
    { name:"Oenothera Biennis (Evening Primrose) Oil", inci:"Oenothera Biennis Oil", cat:"oil", catLabel:"Botanical Oil", catClass:"ing-cat-oil", desc:"Exceptionally rich in gamma-linolenic acid (GLA), an omega-6 fatty acid with strong anti-inflammatory properties. Particularly beneficial for dry, sensitised, or eczema-prone skin, restoring barrier integrity and reducing reactive redness.", products:["Transforming Exfoliator","Probiotic Radiance Masque"] },
    { name:"Oleanolic Acid", inci:"Oleanolic Acid", cat:"botanical", catLabel:"Plant Active", catClass:"ing-cat-botanical", desc:"A pentacyclic triterpenoid found naturally in olive and rosemary. A potent anti-inflammatory and antioxidant that inhibits enzymes involved in skin ageing and reduces sebum production.", products:["Biocinamide Serum"] },
    { name:"Oligopeptide-68", inci:"Oligopeptide-68", cat:"peptide", catLabel:"Brightening Peptide", catClass:"ing-cat-peptide", desc:"A small synthetic peptide specifically designed to inhibit tyrosinase — the key enzyme in melanin synthesis. Targets hyperpigmentation at the source, fading dark spots while being significantly gentler than traditional brightening actives.", products:["Revitalize Brightening Serum"] },
    { name:"Palmitoyl Tetrapeptide-7", inci:"Palmitoyl Tetrapeptide-7", cat:"peptide", catLabel:"Signal Peptide", catClass:"ing-cat-peptide", desc:"Part of the Matrixyl family, this signal peptide downregulates interleukin-6 (IL-6), a key inflammatory cytokine involved in collagen breakdown. By reducing chronic low-grade inflammation, it helps preserve the skin's structural integrity.", products:["Revitalize Anti-Ageing Day Cream SPF 15"] },
    { name:"Palmitoyl Tripeptide-1", inci:"Palmitoyl Tripeptide-1", cat:"peptide", catLabel:"Signal Peptide", catClass:"ing-cat-peptide", desc:"The first component of Matrixyl 3000. Mimics collagen breakdown products to signal fibroblasts that repair is required, stimulating new collagen I, collagen IV, and fibronectin synthesis — measurably improving firmness and reducing wrinkle depth.", products:["Revitalize Anti-Ageing Day Cream SPF 15"] },
    { name:"Palmitoyl Tripeptide-38", inci:"Palmitoyl Tripeptide-38", cat:"peptide", catLabel:"Matrix Peptide", catClass:"ing-cat-peptide", desc:"The active component of Matrixyl synthe'6™. Clinically shown to stimulate synthesis of six major components of the skin matrix simultaneously: collagen I, III, IV, fibronectin, hyaluronic acid, and laminin-5. Visibly reduces wrinkles and restores firmness.", products:["Jellyfish Peptide X Serum","Revitalize Ultimate A Night Cream"] },
    { name:"Panthenol", inci:"Panthenol", cat:"vitamin", catLabel:"Pro-Vitamin B5", catClass:"ing-cat-vitamin", desc:"The provitamin of B5, converted to pantothenic acid in the skin — fundamental to the skin's energy metabolism. A powerful humectant, wound-healing agent, and anti-inflammatory that significantly improves the skin's capacity to regenerate.", products:["Biocinamide Serum","Revitalize Anti-Ageing Day Cream SPF 15"] },
    { name:"Perlite", inci:"Perlite", cat:"mineral", catLabel:"Natural Exfoliant", catClass:"ing-cat-mineral", desc:"A naturally occurring volcanic glass that produces fine, spherical particles when heated. Provides gentle mechanical abrasion to remove dead surface cells and refine texture — without the environmental concerns of synthetic microbeads.", products:["Transforming Exfoliator"] },
    { name:"Persea Gratissima (Avocado) Oil", inci:"Persea Gratissima Oil", cat:"oil", catLabel:"Botanical Oil", catClass:"ing-cat-oil", desc:"Rich in oleic acid, linoleic acid, and vitamins A, D, and E. Penetrates readily to deliver deep moisturisation, barrier reinforcement, and antioxidant protection. Its vitamin A content provides mild retinoid-like cell-renewing benefits.", products:["Rejuvenating Eye Cream","Revitalize Ultimate A Night Cream","Exosome Cream"] },
    { name:"Polymnia Sonchifolia (Yacon) Juice", inci:"Polymnia Sonchifolia Root Juice", cat:"probiotic", catLabel:"Prebiotic", catClass:"ing-cat-probiotic", desc:"Rich in fructooligosaccharides (FOS) — potent prebiotic compounds that selectively nourish beneficial skin flora. Supports microbiome balance essential for barrier health and radiance.", products:["Probiotic Radiance Masque"] },
    { name:"Porphyridium Cruentum Extract", inci:"Porphyridium Cruentum Extract", cat:"hydrator", catLabel:"Marine Active", catClass:"ing-cat-hydrator", desc:"Derived from a red microalgae, rich in exopolysaccharides with exceptional water-binding capacity. Forms a protective film that locks in moisture, soothes sensitised skin, and provides antioxidant defence.", products:["Rejuvenating Eye Cream"] },
    { name:"Retinol", inci:"Retinol", cat:"vitamin", catLabel:"Vitamin A", catClass:"ing-cat-vitamin", desc:"The gold standard of anti-ageing actives with decades of clinical evidence. Converts to retinoic acid in the skin, accelerating cell turnover, stimulating collagen synthesis, and reducing hyperpigmentation. The most evidence-backed approach to treating established wrinkles.", products:["Revitalize Ultimate A Night Cream"] },
    { name:"Rosa Canina (Rosehip) Seed Oil", inci:"Rosa Canina Seed Oil", cat:"oil", catLabel:"Botanical Oil", catClass:"ing-cat-oil", desc:"Naturally rich in trans-retinoic acid (vitamin A), essential fatty acids, and lycopene. Supports skin cell renewal, fades scarring and pigmentation, and softens fine lines. One of skincare's most celebrated regenerative botanicals.", products:["Revitalize Ultimate A Night Cream","Transforming Exfoliator"] },
    { name:"Rosmarinus Officinalis (Rosemary) Leaf Extract", inci:"Rosmarinus Officinalis Leaf Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"An exceptionally rich source of rosmarinic acid and carnosic acid — two of nature's most potent antioxidants. Neutralises free radicals, provides mild antimicrobial action, and acts as an effective natural preservative.", products:["Revitalize Anti-Ageing Day Cream SPF 15"] },
    { name:"Saccharide Isomerate", inci:"Saccharide Isomerate", cat:"hydrator", catLabel:"Biomimetic Hydrator", catClass:"ing-cat-hydrator", desc:"A plant-derived carbohydrate complex analogous to the skin's own Natural Moisturising Factor. Forms a genuine covalent bond with skin proteins, providing lasting hydration for up to 72 hours even after washing — not just a temporary surface effect.", products:["Biocinamide Serum","Jellyfish Peptide X Serum","Revitalize Ultimate A Night Cream","Probiotic Radiance Masque"] },
    { name:"Saccharum Officinarum (Sugar Cane) Extract", inci:"Saccharum Officinarum Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"A natural source of glycolic acid — the smallest and most bioavailable AHA. Provides gentle yet effective exfoliation, improving skin tone, smoothing texture, and enhancing penetration of other actives.", products:["Revitalize Brightening Serum","Transforming Exfoliator"] },
    { name:"Salicylic Acid", inci:"Salicylic Acid", cat:"acid", catLabel:"BHA", catClass:"ing-cat-acid", desc:"The definitive beta-hydroxy acid. Oil-soluble, it penetrates through sebum and into pores, exfoliating the follicle lining from within. Uniquely effective at clearing congestion and preventing breakouts, with anti-inflammatory properties that soothe acne-associated redness.", products:["Revitalize Brightening Serum"] },
    { name:"Sodium Hyaluronate", inci:"Sodium Hyaluronate", cat:"hydrator", catLabel:"Humectant", catClass:"ing-cat-hydrator", desc:"The sodium salt form of hyaluronic acid — a smaller molecule that penetrates more effectively than high-MW HA. Capable of binding up to 1,000× its weight in water, delivering intense hydration that visibly plumps skin and softens fine lines.", products:["Biocinamide Serum","Jellyfish Peptide X Serum","Rejuvenating Eye Cream","Revitalize Anti-Ageing Day Cream SPF 15","Revitalize Ultimate A Night Cream","Probiotic Radiance Masque","Exosome Cream"] },
    { name:"Sodium Hyaluronate Crosspolymer", inci:"Sodium Hyaluronate Crosspolymer", cat:"hydrator", catLabel:"Humectant", catClass:"ing-cat-hydrator", desc:"A cross-linked form of hyaluronic acid that persists on the skin longer than standard HA. Forms a water-retaining film providing sustained hydration and improved skin viscoelasticity, plumping the appearance of wrinkles more durably over time.", products:["Revitalize Ultimate A Night Cream"] },
    { name:"Sodium PCA", inci:"Sodium PCA", cat:"hydrator", catLabel:"NMF Component", catClass:"ing-cat-hydrator", desc:"The sodium salt of pyrrolidone carboxylic acid — one of the most abundant components of the skin's own Natural Moisturising Factor. An extremely effective humectant, highly compatible with skin biology.", products:["Biocinamide Serum","Daily Devotion Cleanser","Jellyfish Peptide X Serum","Rejuvenating Eye Cream","Revitalize Anti-Ageing Day Cream SPF 15","Revitalize Brightening Serum","Revitalize Ultimate A Night Cream","Probiotic Radiance Masque","Exosome Cream"] },
    { name:"Squalane", inci:"Squalane", cat:"oil", catLabel:"Emollient", catClass:"ing-cat-oil", desc:"The stable, hydrogenated form of squalene (now derived from sugarcane or olive). Skin-identical, lightweight, non-comedogenic. Provides superb emolliency, antioxidant protection, and barrier reinforcement without any greasy feel.", products:["Rejuvenating Eye Cream"] },
    { name:"Squalene", inci:"Squalene", cat:"oil", catLabel:"Emollient", catClass:"ing-cat-oil", desc:"A naturally occurring lipid and key component of human sebum that declines after age 25. Softens and smooths the skin surface, provides antioxidant action, and helps restore the skin's natural lipid balance.", products:["Jellyfish Peptide X Serum","Revitalize Ultimate A Night Cream","Probiotic Radiance Masque"] },
    { name:"Tartaric Acid", inci:"Tartaric Acid", cat:"acid", catLabel:"AHA", catClass:"ing-cat-acid", desc:"A naturally occurring AHA from grapes and tamarind, contributing gentle exfoliation and antioxidant activity to multi-acid brightening formulas. Its larger molecular size makes it the gentlest of the AHAs included, broadening suitability across skin types.", products:["Revitalize Brightening Serum"] },
    { name:"Terminalia Ferdinandiana (Kakadu Plum) Fruit Extract", inci:"Terminalia Ferdinandiana Fruit Extract", cat:"botanical", catLabel:"Australian Botanical", catClass:"ing-cat-botanical", desc:"Native to the Northern Territory and Western Australia, the Kakadu Plum holds the highest recorded natural concentration of Vitamin C of any fruit on Earth — up to 100× that of an orange. Delivers exceptional antioxidant protection, inhibits melanin synthesis, and stimulates collagen production.", products:["Jellyfish Peptide X Serum"] },
    { name:"Theobroma Grandiflorum (Cupuacu) Seed Butter", inci:"Theobroma Grandiflorum Seed Butter", cat:"oil", catLabel:"Emollient Butter", catClass:"ing-cat-oil", desc:"From the Amazonian cupuacu tree, this butter has a remarkable capacity to absorb water — up to 400% of its own weight. Provides deep, sustained hydration while replenishing the skin's lipid matrix, leaving skin soft, supple, and protected.", products:["Revitalize Ultimate A Night Cream"] },
    { name:"Tocopherol / Tocopheryl Acetate", inci:"Tocopherol / Tocopheryl Acetate", cat:"vitamin", catLabel:"Vitamin E", catClass:"ing-cat-vitamin", desc:"The primary fat-soluble antioxidant in skin. Provides essential protection against oxidative stress from UV and pollution, supports barrier lipid integrity, and works synergistically with Vitamin C for enhanced photoprotection.", products:["Jellyfish Peptide X Serum","Revitalize Anti-Ageing Day Cream SPF 15","Probiotic Radiance Masque","Exosome Cream"] },
    { name:"Vaccinium Myrtillus (Bilberry) Fruit Extract", inci:"Vaccinium Myrtillus Fruit Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"A natural source of AHAs and anthocyanin antioxidants. Contributes gentle exfoliation, potent antioxidant defence through anthocyanins, and improved microcirculation.", products:["Revitalize Brightening Serum","Transforming Exfoliator"] },
    { name:"Zingiber Officinale (Ginger) Root Extract", inci:"Zingiber Officinale Root Extract", cat:"botanical", catLabel:"Botanical", catClass:"ing-cat-botanical", desc:"Rich in gingerols and shogaols — potent antioxidant and anti-inflammatory compounds. Neutralises free radicals, calms inflammation, improves microcirculation in the dermis, and has demonstrated tyrosinase-inhibiting properties.", products:["Biocinamide Serum"] }
  ];

  let ingActiveFilter = 'all';
  let ingSearchTerm = '';

  function ingGetFiltered() {
    return ING_DATA.filter(function(ing) {
      var matchFilter = ingActiveFilter === 'all' || ing.cat === ingActiveFilter;
      var matchSearch = !ingSearchTerm ||
        ing.name.toLowerCase().indexOf(ingSearchTerm) > -1 ||
        ing.inci.toLowerCase().indexOf(ingSearchTerm) > -1 ||
        ing.desc.toLowerCase().indexOf(ingSearchTerm) > -1;
      return matchFilter && matchSearch;
    });
  }

  function ingRender() {
    var filtered = ingGetFiltered();
    var main = document.getElementById('ingMain');
    var noResults = document.getElementById('ingNoResults');
    var count = document.getElementById('ingSearchCount');

    count.textContent = (ingSearchTerm || ingActiveFilter !== 'all')
      ? 'Showing ' + filtered.length + ' ingredient' + (filtered.length !== 1 ? 's' : '')
      : 'Showing all ' + ING_DATA.length + ' ingredients';

    Array.from(main.querySelectorAll('.ing-letter-section')).forEach(function(el) { el.remove(); });

    if (filtered.length === 0) {
      noResults.style.display = 'block';
      ingRenderAZ({});
      return;
    }
    noResults.style.display = 'none';

    var grouped = {};
    filtered.forEach(function(ing) {
      var letter = ing.name[0].toUpperCase();
      if (!grouped[letter]) grouped[letter] = [];
      grouped[letter].push(ing);
    });

    Object.keys(grouped).sort().forEach(function(letter) {
      var section = document.createElement('div');
      section.className = 'ing-letter-section ing-fade-up';
      section.id = 'ing-letter-' + letter;

      var cards = grouped[letter].map(function(ing) {
        var products = ing.products.map(function(p) {
          return '<span class="ing-product-tag">' + p + '</span>';
        }).join('');
        return '<div class="ing-card" data-cat="' + ing.cat + '">' +
          '<div class="ing-card-header">' +
            '<div class="ing-card-name-block">' +
              '<div class="ing-card-name">' + ing.name + '</div>' +
              '<div class="ing-card-inci">' + ing.inci + '</div>' +
            '</div>' +
            '<span class="ing-cat-pill ' + ing.catClass + '">' + ing.catLabel + '</span>' +
          '</div>' +
          '<p class="ing-card-desc">' + ing.desc + '</p>' +
          '<div class="ing-found-in">' +
            '<span class="ing-found-in-label">Found in</span>' +
            products +
          '</div>' +
        '</div>';
      }).join('');

      section.innerHTML = '<div class="ing-letter-heading">' + letter + '</div>' +
        '<div class="ing-grid">' + cards + '</div>';

      main.appendChild(section);
    });

    requestAnimationFrame(function() {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('ing-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.05 });
      main.querySelectorAll('.ing-fade-up').forEach(function(el) { observer.observe(el); });
    });

    ingRenderAZ(grouped);
  }

  function ingRenderAZ(grouped) {
    var nav = document.getElementById('ingAzNav');
    nav.innerHTML = '';
    'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').forEach(function(letter) {
      var btn = document.createElement('button');
      btn.className = 'ing-az-btn' + (grouped[letter] ? ' has-items' : ' inactive');
      btn.textContent = letter;
      if (grouped[letter]) {
        btn.onclick = function() {
          var el = document.getElementById('ing-letter-' + letter);
          if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        };
      }
      nav.appendChild(btn);
    });
  }

  window.ingSetFilter = function(cat, btn) {
    ingActiveFilter = cat;
    document.querySelectorAll('.ing-filter-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    ingRender();
  };

  window.ingFilterIngredients = function() {
    ingSearchTerm = document.getElementById('ingSearchInput').value.toLowerCase().trim();
    ingRender();
  };

  ingRender();
})();
</script>

