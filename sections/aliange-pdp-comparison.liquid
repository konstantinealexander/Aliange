{% comment %}
  Aliangé PDP Comparison Table
  Two-column "Us vs Them" style: dark left column (Aliangé), light right column (competitors).
{% endcomment %}


{%- style -%}
  #pdp-comparison-{{ section.id }} {
    background-color: var(--pdp-bg);
    padding: var(--pdp-space-xl) var(--pdp-space-md);
  }
  #pdp-comparison-{{ section.id }} .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--pdp-space-xl);
  }

  /* Grid wrapper — all cells sit directly in it */
  #pdp-comparison-{{ section.id }} .comparison-grid {
    max-width: 720px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  /* Column backgrounds */
  #pdp-comparison-{{ section.id }} .cell-us {
    background: #1a1a1a;
    color: #ffffff;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  #pdp-comparison-{{ section.id }} .cell-them {
    background: #ffffff;
    color: var(--pdp-ink);
    border-bottom: 1px solid var(--pdp-border);
    border-right: 1px solid var(--pdp-border);
  }

  /* Last row: remove bottom borders */
  #pdp-comparison-{{ section.id }} .cell-us.last-row,
  #pdp-comparison-{{ section.id }} .cell-them.last-row {
    border-bottom: none;
  }

  /* Column headers */
  #pdp-comparison-{{ section.id }} .col-header {
    padding: 28px 24px 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 88px;
  }
  #pdp-comparison-{{ section.id }} .cell-us.col-header {
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  #pdp-comparison-{{ section.id }} .cell-them.col-header {
    border-bottom: 1px solid var(--pdp-border);
  }
  #pdp-comparison-{{ section.id }} .col-header img {
    height: 30px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    filter: invert(1);
  }
  #pdp-comparison-{{ section.id }} .header-brand-text,
  #pdp-comparison-{{ section.id }} .header-competitor-text {
    font-family: var(--pdp-font-body);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  #pdp-comparison-{{ section.id }} .header-brand-text { color: #ffffff; }
  #pdp-comparison-{{ section.id }} .header-competitor-text { color: var(--pdp-ink); }

  /* Data rows */
  #pdp-comparison-{{ section.id }} .row-cell {
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--pdp-font-body);
    font-size: 14px;
    line-height: 1.4;
    min-height: 56px;
  }
  #pdp-comparison-{{ section.id }} .row-cell .cell-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
  }
  #pdp-comparison-{{ section.id }} .icon-check { color: #4caf50; }
  #pdp-comparison-{{ section.id }} .icon-cross { color: #e57373; }

  @media (max-width: 560px) {
    #pdp-comparison-{{ section.id }} .row-cell {
      padding: 12px 14px;
      font-size: 13px;
      gap: 8px;
      min-height: 48px;
    }
    #pdp-comparison-{{ section.id }} .col-header {
      padding: 20px 14px 16px;
      min-height: 72px;
    }
    #pdp-comparison-{{ section.id }} .row-cell .cell-icon {
      width: 18px;
      height: 18px;
    }
  }
{%- endstyle -%}

<section id="pdp-comparison-{{ section.id }}" class="scroll-reveal">
  <div class="section-header">
    <h2 class="h2" style="margin-bottom:10px;">{{ section.settings.heading }}</h2>
    <p class="p-lg">{{ section.settings.subheading }}</p>
  </div>

  <div class="comparison-grid">

    {%- comment -%} Header row {%- endcomment -%}
    <div class="cell-us col-header">
      {% if section.settings.logo_asset != blank %}
        <img src="{{ section.settings.logo_asset | asset_url }}" alt="{{ section.settings.aliange_label }}">
      {% else %}
        <span class="header-brand-text">{{ section.settings.aliange_label }}</span>
      {% endif %}
    </div>
    <div class="cell-them col-header">
      <span class="header-competitor-text">{{ section.settings.competitor_label }}</span>
    </div>

    {%- comment -%} Data rows {%- endcomment -%}
    {% for block in section.blocks %}
      {%- assign is_last = forloop.last -%}
      <div class="cell-us row-cell {% if is_last %}last-row{% endif %}" {{ block.shopify_attributes }}>
        <svg class="cell-icon icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm45.66,85.66-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32Z"/></svg>
        <span>{{ block.settings.aliange_value }}</span>
      </div>
      <div class="cell-them row-cell {% if is_last %}last-row{% endif %}">
        <svg class="cell-icon icon-cross" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm37.66,130.34a8,8,0,0,1-11.32,11.32L128,139.31l-26.34,26.35a8,8,0,0,1-11.32-11.32L116.69,128,90.34,101.66a8,8,0,0,1,11.32-11.32L128,116.69l26.34-26.35a8,8,0,0,1,11.32,11.32L139.31,128Z"/></svg>
        <span>{{ block.settings.competitor_value }}</span>
      </div>
    {% endfor %}

  </div>
</section>

{% schema %}
{
  "name": "Comparison Table",
  "tag": "section",
  "class": "aliange-pdp-comparison",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Us vs Them"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Why Aliangé outperforms the rest"
    },
    {
      "type": "text",
      "id": "logo_asset",
      "label": "Logo Asset Filename (e.g. aliange-wordmark.png)"
    },
    {
      "type": "text",
      "id": "aliange_label",
      "label": "Brand Label (shown if no logo file set)",
      "default": "ALIANGÉ"
    },
    {
      "type": "text",
      "id": "competitor_label",
      "label": "Competitor Column Label",
      "default": "Named Brands"
    }
  ],
  "blocks": [
    {
      "type": "comparison_row",
      "name": "Comparison Row",
      "settings": [
        {
          "type": "text",
          "id": "aliange_value",
          "label": "Aliangé (left column)",
          "default": "Natural fibers"
        },
        {
          "type": "text",
          "id": "competitor_value",
          "label": "Competitor (right column)",
          "default": "Polyester, Nylon, Elastane"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        { "type": "comparison_row", "settings": { "aliange_value": "Natural fibers", "competitor_value": "Polyester, Nylon, Elastane" } },
        { "type": "comparison_row", "settings": { "aliange_value": "Low Impact Dyes", "competitor_value": "Uses harsh dyes" } },
        { "type": "comparison_row", "settings": { "aliange_value": "GOTS certified", "competitor_value": "Synthetic, not organic" } },
        { "type": "comparison_row", "settings": { "aliange_value": "Microplastic free", "competitor_value": "Sheds plastic fibers" } }
      ]
    }
  ]
}
{% endschema %}
