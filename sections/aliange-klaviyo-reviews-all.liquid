<section class="aliange-reviews aliange-reviews--all section-spacing">
  <div class="container">
    <div class="aliange-reviews__header">
      <p class="aliange-reviews__label">What Our Customers Say</p>
      <h2 class="aliange-reviews__heading">Verified Reviews</h2>
    </div>
    <div class="aliange-reviews__grid" id="aliange-reviews-all-{{ section.id }}">
      <div class="aliange-reviews__loading">Loading reviews…</div>
    </div>
    <div class="aliange-reviews__pagination" id="aliange-reviews-all-nav-{{ section.id }}" style="display:none;">
      <button class="aliange-reviews__btn" id="aliange-reviews-prev-{{ section.id }}" disabled>← Prev</button>
      <span class="aliange-reviews__page-info" id="aliange-reviews-info-{{ section.id }}"></span>
      <button class="aliange-reviews__btn" id="aliange-reviews-next-{{ section.id }}">Next →</button>
    </div>
  </div>
</section>

<style>
  .aliange-reviews {
    padding: 64px 0;
    background: #faf9f7;
  }
  .aliange-reviews__header {
    text-align: center;
    margin-bottom: 40px;
  }
  .aliange-reviews__label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 8px;
  }
  .aliange-reviews__heading {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 500;
    color: #1a1814;
  }
  .aliange-reviews__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }
  .aliange-reviews__loading,
  .aliange-reviews__empty,
  .aliange-reviews__error {
    grid-column: 1 / -1;
    text-align: center;
    color: #888;
    padding: 40px 0;
    font-size: 15px;
  }
  .aliange-review-card {
    background: #fff;
    border: 1px solid #e8e4de;
    border-radius: 4px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .aliange-review-card__stars {
    color: #c8a96e;
    font-size: 16px;
    letter-spacing: 2px;
  }
  .aliange-review-card__title {
    font-size: 15px;
    font-weight: 600;
    color: #1a1814;
    margin: 0;
  }
  .aliange-review-card__body {
    font-size: 14px;
    line-height: 1.65;
    color: #4a4845;
    margin: 0;
    flex: 1;
  }
  .aliange-review-card__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 8px;
    border-top: 1px solid #f0ede8;
  }
  .aliange-review-card__author {
    font-size: 13px;
    font-weight: 500;
    color: #1a1814;
    margin: 0;
  }
  .aliange-review-card__product {
    font-size: 12px;
    color: #888;
    margin: 0;
  }
  .aliange-review-card__date {
    font-size: 12px;
    color: #aaa;
    margin: 0;
  }
  .aliange-reviews__pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 40px;
  }
  .aliange-reviews__btn {
    padding: 10px 24px;
    border: 1px solid #1a1814;
    background: transparent;
    color: #1a1814;
    font-size: 13px;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .aliange-reviews__btn:hover:not(:disabled) {
    background: #1a1814;
    color: #fff;
  }
  .aliange-reviews__btn:disabled {
    opacity: 0.3;
    cursor: default;
  }
  .aliange-reviews__page-info {
    font-size: 13px;
    color: #888;
    min-width: 80px;
    text-align: center;
  }
</style>

<script>
(function () {
  var PUBLIC_KEY = 'RWyTn6';
  var PER_PAGE = 9;
  var containerId = 'aliange-reviews-all-{{ section.id }}';
  var navId = 'aliange-reviews-all-nav-{{ section.id }}';
  var prevId = 'aliange-reviews-prev-{{ section.id }}';
  var nextId = 'aliange-reviews-next-{{ section.id }}';
  var infoId = 'aliange-reviews-info-{{ section.id }}';

  var container = document.getElementById(containerId);
  var nav = document.getElementById(navId);
  var prevBtn = document.getElementById(prevId);
  var nextBtn = document.getElementById(nextId);
  var info = document.getElementById(infoId);

  var allReviews = [];
  var currentPage = 0;

  function stars(rating) {
    var s = '';
    for (var i = 1; i <= 5; i++) s += i <= rating ? '★' : '☆';
    return s;
  }

  function formatDate(iso) {
    if (!iso) return '';
    var d = new Date(iso);
    return d.toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' });
  }

  function renderPage(page) {
    var start = page * PER_PAGE;
    var slice = allReviews.slice(start, start + PER_PAGE);
    container.innerHTML = slice.map(function (r) {
      var a = r.attributes;
      return '<div class="aliange-review-card">' +
        '<div class="aliange-review-card__stars">' + stars(a.rating || 5) + '</div>' +
        (a.title ? '<p class="aliange-review-card__title">' + escHtml(a.title) + '</p>' : '') +
        '<p class="aliange-review-card__body">' + escHtml(a.content || a.body || '') + '</p>' +
        '<div class="aliange-review-card__meta">' +
          '<p class="aliange-review-card__author">' + escHtml(a.author_name || a.reviewer_name || 'Verified Customer') + '</p>' +
          (a.product_name ? '<p class="aliange-review-card__product">' + escHtml(a.product_name) + '</p>' : '') +
          '<p class="aliange-review-card__date">' + formatDate(a.created_at || a.submitted_at) + '</p>' +
        '</div>' +
      '</div>';
    }).join('');

    var totalPages = Math.ceil(allReviews.length / PER_PAGE);
    info.textContent = 'Page ' + (page + 1) + ' of ' + totalPages;
    prevBtn.disabled = page === 0;
    nextBtn.disabled = page >= totalPages - 1;
    currentPage = page;
    if (allReviews.length > PER_PAGE) nav.style.display = 'flex';
  }

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function fetchAll(url, acc) {
    return fetch(url, { headers: { 'revision': '2024-10-15' } })
    .then(function (r) {
      console.log('[Klaviyo Reviews] status', r.status, url);
      return r.json();
    })
    .then(function (json) {
      console.log('[Klaviyo Reviews] response', json);
      var rows = (json.data || []).filter(function(r){ return r.attributes; });
      acc = acc.concat(rows);
      if (json.links && json.links.next) {
        return fetchAll(json.links.next, acc);
      }
      return acc;
    });
  }

  var baseUrl = 'https://a.klaviyo.com/client/reviews/?company_id=' + PUBLIC_KEY + '&page[size]=100&sort=-created_at&revision=2024-10-15';
  fetchAll(baseUrl, [])
    .then(function (reviews) {
      if (!reviews.length) {
        container.innerHTML = '<p class="aliange-reviews__empty">No published reviews yet.</p>';
        return;
      }
      allReviews = reviews;
      renderPage(0);
      prevBtn.addEventListener('click', function () { renderPage(currentPage - 1); window.scrollTo({top: container.offsetTop - 80, behavior: 'smooth'}); });
      nextBtn.addEventListener('click', function () { renderPage(currentPage + 1); window.scrollTo({top: container.offsetTop - 80, behavior: 'smooth'}); });
    })
    .catch(function (e) {
      container.innerHTML = '<p class="aliange-reviews__error">Could not load reviews. Please try again later.</p>';
      console.error('Klaviyo Reviews error:', e);
    });
})();
</script>

{% schema %}
{
  "name": "Klaviyo — All Reviews",
  "settings": []
}
{% endschema %}
