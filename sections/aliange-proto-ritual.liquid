{% render 'aliange-lp-styles' %}

{%- style -%}
  #proto-ritual-{{ section.id }} { background-color: var(--lp-bg-muted); }
  #proto-ritual-{{ section.id }} .proto-ritual-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--lp-space-2xl);
  }
  #proto-ritual-{{ section.id }} .proto-ritual-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--lp-space-lg);
    max-width: var(--lp-container-sm);
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    #proto-ritual-{{ section.id }} .proto-ritual-columns { grid-template-columns: 1fr 1fr; }
  }
  #proto-ritual-{{ section.id }} .proto-ritual-col {
    background-color: var(--lp-bg);
    border: 1px solid var(--lp-border);
    border-radius: var(--lp-radius-lg);
    padding: var(--lp-space-xl);
  }
  #proto-ritual-{{ section.id }} .proto-ritual-col--am {
    border-top: 3px solid #E8B931;
  }
  #proto-ritual-{{ section.id }} .proto-ritual-col--pm {
    border-top: 3px solid #6B7DB3;
  }
  #proto-ritual-{{ section.id }} .proto-ritual-col-label {
    font-family: var(--lp-font-heading);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 var(--lp-space-lg);
  }
  #proto-ritual-{{ section.id }} .proto-ritual-col--am .proto-ritual-col-label { color: #C49A1A; }
  #proto-ritual-{{ section.id }} .proto-ritual-col--pm .proto-ritual-col-label { color: #5668A0; }
  #proto-ritual-{{ section.id }} .proto-ritual-steps {
    display: flex;
    flex-direction: column;
    gap: var(--lp-space-sm);
    counter-reset: ritual-step;
  }
  #proto-ritual-{{ section.id }} .proto-ritual-step {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: var(--lp-space-sm);
    align-items: baseline;
    counter-increment: ritual-step;
  }
  #proto-ritual-{{ section.id }} .proto-ritual-step-num {
    font-family: var(--lp-font-heading);
    font-size: 13px;
    font-weight: 700;
    color: var(--lp-body);
    opacity: 0.5;
  }
  #proto-ritual-{{ section.id }} .proto-ritual-step-num::before { content: counter(ritual-step) "."; }
  #proto-ritual-{{ section.id }} .proto-ritual-step-text {
    font-family: var(--lp-font-body);
    font-size: 14px;
    color: var(--lp-ink);
    line-height: 1.5;
    margin: 0;
  }
  #proto-ritual-{{ section.id }} .proto-ritual-step-freq {
    font-size: 12px;
    font-weight: 600;
    color: var(--lp-body);
    opacity: 0.7;
  }
  #proto-ritual-{{ section.id }} .proto-ritual-note {
    font-family: var(--lp-font-body);
    font-size: 13px;
    color: var(--lp-body);
    line-height: 1.5;
    margin: var(--lp-space-lg) 0 0;
    font-style: italic;
    opacity: 0.8;
  }
{%- endstyle -%}

<section id="proto-ritual-{{ section.id }}" class="lp-section">
  <div class="lp-container">
    <div class="proto-ritual-header lp-reveal">
      {%- if section.settings.label != blank -%}
        <span class="lp-section-label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="lp-heading-lg">{{ section.settings.headline }}</h2>
    </div>

    <div class="proto-ritual-columns lp-reveal">
      {%- comment -%}AM Column{%- endcomment -%}
      <div class="proto-ritual-col proto-ritual-col--am">
        <div class="proto-ritual-col-label">☀️ Morning</div>
        <div class="proto-ritual-steps">
          {%- for block in section.blocks -%}
            {%- if block.settings.time == 'am' or block.settings.time == 'both' -%}
              <div class="proto-ritual-step" {{ block.shopify_attributes }}>
                <span class="proto-ritual-step-num"></span>
                <p class="proto-ritual-step-text">
                  {{ block.settings.text }}
                  {%- if block.settings.frequency != blank -%}
                    <span class="proto-ritual-step-freq"> ({{ block.settings.frequency }})</span>
                  {%- endif -%}
                </p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- if section.settings.am_note != blank -%}
          <p class="proto-ritual-note">{{ section.settings.am_note }}</p>
        {%- endif -%}
      </div>

      {%- comment -%}PM Column{%- endcomment -%}
      <div class="proto-ritual-col proto-ritual-col--pm">
        <div class="proto-ritual-col-label">🌙 Evening</div>
        <div class="proto-ritual-steps">
          {%- for block in section.blocks -%}
            {%- if block.settings.time == 'pm' or block.settings.time == 'both' -%}
              <div class="proto-ritual-step" {{ block.shopify_attributes }}>
                <span class="proto-ritual-step-num"></span>
                <p class="proto-ritual-step-text">
                  {{ block.settings.text }}
                  {%- if block.settings.frequency != blank -%}
                    <span class="proto-ritual-step-freq"> ({{ block.settings.frequency }})</span>
                  {%- endif -%}
                </p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- if section.settings.pm_note != blank -%}
          <p class="proto-ritual-note">{{ section.settings.pm_note }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% render 'aliange-lp-scripts' %}

{% schema %}
{
  "name": "Protocol — AM/PM Ritual",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow label", "default": "Your Daily Ritual" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Your Daily Ritual" },
    { "type": "textarea", "id": "am_note", "label": "AM note (italic)", "info": "Optional note below the AM column" },
    { "type": "textarea", "id": "pm_note", "label": "PM note (italic)", "info": "Optional note below the PM column" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Ritual Step",
      "limit": 10,
      "settings": [
        { "type": "text", "id": "text", "label": "Step text", "default": "Cleanse with Daily Devotion Cleanser" },
        {
          "type": "select",
          "id": "time",
          "label": "Time of day",
          "options": [
            { "value": "am", "label": "AM only" },
            { "value": "pm", "label": "PM only" },
            { "value": "both", "label": "AM & PM" }
          ],
          "default": "both"
        },
        { "type": "text", "id": "frequency", "label": "Frequency note", "info": "e.g. '2-3x/week'" }
      ]
    }
  ],
  "presets": [{ "name": "Protocol — AM/PM Ritual" }]
}
{% endschema %}
