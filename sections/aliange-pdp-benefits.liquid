{% comment %}
  Aliangé PDP Benefits Section
  Two-column: benefit cards (left) + lifestyle image (right).
  All content editable via schema blocks.
{% endcomment %}

{%- style -%}
  #pdp-benefits-{{ section.id }} .benefits-header {
    text-align: {{ section.settings.header_align }};
    margin-bottom: var(--pdp-space-xl);
  }

  @media (min-width: 768px) {
    #pdp-benefits-{{ section.id }} .benefits-header {
      margin-bottom: var(--pdp-space-2xl);
    }
  }

  #pdp-benefits-{{ section.id }} .benefits-header .pdp-heading {
    margin-bottom: var(--pdp-space-sm);
  }

  #pdp-benefits-{{ section.id }} .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--pdp-space-xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    #pdp-benefits-{{ section.id }} .benefits-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--pdp-space-2xl);
    }
  }

  #pdp-benefits-{{ section.id }} .benefits-cards {
    display: flex;
    flex-direction: column;
    gap: var(--pdp-space-sm);
  }

  #pdp-benefits-{{ section.id }} .benefit-card {
    display: flex;
    align-items: flex-start;
    gap: var(--pdp-space-md);
    padding: var(--pdp-space-md) var(--pdp-space-lg);
    background-color: var(--pdp-bg-muted);
    border-radius: var(--pdp-radius-md);
    transition: transform var(--pdp-duration-slow) var(--pdp-ease),
                box-shadow var(--pdp-duration-slow) var(--pdp-ease);
  }

  #pdp-benefits-{{ section.id }} .benefit-card:hover {
    transform: translateY(-1px);
    box-shadow: var(--pdp-shadow-sm);
  }

  @media (prefers-reduced-motion: reduce) {
    #pdp-benefits-{{ section.id }} .benefit-card:hover {
      transform: none;
    }
  }

  #pdp-benefits-{{ section.id }} .benefit-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    margin-top: 2px;
    color: var(--pdp-ink);
    opacity: 0.7;
  }

  #pdp-benefits-{{ section.id }} .benefit-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  #pdp-benefits-{{ section.id }} .benefit-title {
    font-family: var(--pdp-font-body);
    font-weight: 600;
    font-size: 15px;
    color: var(--pdp-ink);
    line-height: 1.4;
    margin: 0;
  }

  @media (min-width: 768px) {
    #pdp-benefits-{{ section.id }} .benefit-title {
      font-size: 16px;
    }
  }

  #pdp-benefits-{{ section.id }} .benefit-desc {
    font-family: var(--pdp-font-body);
    font-size: 13px;
    color: var(--pdp-body);
    line-height: 1.6;
    margin: 0;
  }

  @media (min-width: 768px) {
    #pdp-benefits-{{ section.id }} .benefit-desc {
      font-size: 14px;
    }
  }

  #pdp-benefits-{{ section.id }} .benefits-image {
    position: relative;
    border-radius: var(--pdp-radius-xl);
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background-color: var(--pdp-bg-muted);
  }

  #pdp-benefits-{{ section.id }} .benefits-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #pdp-benefits-{{ section.id }} .benefits-footer {
    margin-top: var(--pdp-space-lg);
  }
{%- endstyle -%}

<section id="pdp-benefits-{{ section.id }}" class="pdp-section pdp-reveal" aria-label="Product benefits">
  <div class="pdp-container">
    {% if section.settings.heading != blank %}
      <div class="benefits-header">
        <h2 class="pdp-heading pdp-heading--lg">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="pdp-body pdp-body--md">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="benefits-grid">
      <div class="benefits-cards">
        {% assign benefits = section.blocks | where: "type", "benefit" %}
        {% for block in benefits %}
          <div class="benefit-card" {{ block.shopify_attributes }}>
            <svg class="benefit-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" width="28" height="28" aria-hidden="true">
              <path d="M225.86,102.82c-3.77-3.94-7.67-8-9.14-11.57-1.36-3.27-1.44-8.69-1.52-13.94-.15-9.76-.31-20.82-8-28.51s-18.75-7.85-28.51-8c-5.25-.08-10.67-.16-13.94-1.52-3.56-1.47-7.63-5.37-11.57-9.14C146.28,23.51,138.44,16,128,16s-18.27,7.51-25.18,14.14c-3.94,3.77-8,7.67-11.57,9.14C88,40.64,82.56,40.72,77.31,40.8c-9.76.15-20.82.31-28.51,8S41,67.55,40.8,77.31c-.08,5.25-.16,10.67-1.52,13.94-1.47,3.56-5.37,7.63-9.14,11.57C23.51,109.72,16,117.56,16,128s7.51,18.27,14.14,25.18c3.77,3.94,7.67,8,9.14,11.57,1.36,3.27,1.44,8.69,1.52,13.94.15,9.76.31,20.82,8,28.51s18.75,7.85,28.51,8c5.25.08,10.67.16,13.94,1.52,3.56,1.47,7.63,5.37,11.57,9.14C109.72,232.49,117.56,240,128,240s18.27-7.51,25.18-14.14c3.94-3.77,8-7.67,11.57-9.14,3.27-1.36,8.69-1.44,13.94-1.52,9.76-.15,20.82-.31,28.51-8s7.85-18.75,8-28.51c.08-5.25.16-10.67,1.52-13.94,1.47-3.56,5.37-7.63,9.14-11.57C232.49,146.28,240,138.44,240,128S232.49,109.73,225.86,102.82ZM173.66,98.34a8,8,0,0,1,0,11.32l-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35A8,8,0,0,1,173.66,98.34Z"/>
            </svg>
            <div class="benefit-content">
              {% if block.settings.title != blank %}
                <h3 class="benefit-title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <p class="benefit-desc">{{ block.settings.description }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}

        {% if section.settings.button_text != blank %}
          <div class="benefits-footer">
            <a href="{{ section.settings.button_url | default: '#' }}" class="pdp-btn pdp-btn--primary pdp-btn--full">
              <span>{{ section.settings.button_text }}</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"/></svg>
            </a>
          </div>
        {% endif %}
      </div>

      {% if section.settings.image != blank %}
        <div class="benefits-image">
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image.alt | default: 'Product benefits' | escape }}"
            width="800"
            height="800"
            loading="lazy"
          >
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% render 'aliange-pdp-scripts' %}

{% schema %}
{
  "name": "PDP Benefits",
  "tag": "section",
  "class": "aliange-pdp-benefits",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Advanced Daily Protection & Repair"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A multi-action formula designed to defend against environmental damage while visibly rejuvenating the skin."
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Defends Against Sun Ageing"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Our broad-spectrum SPF 15 formula provides essential daily protection against UV radiation."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Benefits",
      "blocks": [
        { "type": "benefit", "settings": { "title": "Defends Against Sun Ageing", "description": "Our broad-spectrum SPF 15 provides essential daily protection against UV radiation." } },
        { "type": "benefit", "settings": { "title": "Visibly Reduces Wrinkles", "description": "Powered by Matrixyl 3000, smooths fine lines by up to 41% in 8 weeks." } },
        { "type": "benefit", "settings": { "title": "Deep, Lasting Hydration", "description": "Sodium Hyaluronate and Sodium PCA draw moisture deep into the skin." } },
        { "type": "benefit", "settings": { "title": "Soothes Stressed Skin", "description": "Centella Asiatica, Echinacea, and Rosemary calm irritation and redness." } }
      ]
    }
  ]
}
{% endschema %}
