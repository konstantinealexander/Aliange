{% comment %}
  Aliangé LP Comparison Table
  Two-column "Us vs Them" style matching the PDP comparison design.
{% endcomment %}

{%- style -%}
  #lp-comparison-{{ section.id }} {
    background-color: var(--lp-bg);
    padding: var(--lp-space-2xl) var(--lp-space-md);
  }
  #lp-comparison-{{ section.id }} .lp-comparison-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--lp-space-xl);
  }

  /* Grid wrapper */
  #lp-comparison-{{ section.id }} .comparison-grid {
    max-width: 720px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  /* Column backgrounds */
  #lp-comparison-{{ section.id }} .cell-us {
    background: var(--lp-bg-dark);
    color: #ffffff;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  #lp-comparison-{{ section.id }} .cell-them {
    background: #ffffff;
    color: var(--lp-ink);
    border-bottom: 1px solid var(--lp-border);
    border-right: 1px solid var(--lp-border);
  }
  #lp-comparison-{{ section.id }} .cell-us.last-row,
  #lp-comparison-{{ section.id }} .cell-them.last-row {
    border-bottom: none;
  }

  /* Column headers */
  #lp-comparison-{{ section.id }} .col-header {
    padding: 28px 24px 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 88px;
  }
  #lp-comparison-{{ section.id }} .cell-us.col-header {
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  #lp-comparison-{{ section.id }} .cell-them.col-header {
    border-bottom: 1px solid var(--lp-border);
  }
  #lp-comparison-{{ section.id }} .header-brand-text,
  #lp-comparison-{{ section.id }} .header-competitor-text {
    font-family: var(--lp-font-body);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  #lp-comparison-{{ section.id }} .header-brand-text { color: #ffffff; }
  #lp-comparison-{{ section.id }} .header-competitor-text { color: var(--lp-ink); }

  /* Data rows */
  #lp-comparison-{{ section.id }} .row-cell {
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--lp-font-body);
    font-size: 14px;
    line-height: 1.4;
    min-height: 56px;
  }
  #lp-comparison-{{ section.id }} .cell-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
  }
  #lp-comparison-{{ section.id }} .icon-check { color: #4caf50; }
  #lp-comparison-{{ section.id }} .icon-cross { color: #e57373; }

  @media (max-width: 560px) {
    #lp-comparison-{{ section.id }} .row-cell {
      padding: 12px 14px;
      font-size: 13px;
      gap: 8px;
      min-height: 48px;
    }
    #lp-comparison-{{ section.id }} .col-header {
      padding: 20px 14px 16px;
      min-height: 72px;
    }
    #lp-comparison-{{ section.id }} .cell-icon {
      width: 18px;
      height: 18px;
    }
  }
{%- endstyle -%}

<section id="lp-comparison-{{ section.id }}" class="lp-section">
  <div class="lp-container">
    <div class="lp-comparison-header lp-reveal">
      {%- if section.settings.label != blank -%}
        <span class="lp-section-label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="lp-heading-lg">{{ section.settings.headline }}</h2>
    </div>

    <div class="comparison-grid lp-reveal">

      {%- comment -%} Header row {%- endcomment -%}
      <div class="cell-us col-header">
        <span class="header-brand-text">{{ section.settings.col_us | default: 'Aliangé' }}</span>
      </div>
      <div class="cell-them col-header">
        <span class="header-competitor-text">{{ section.settings.col_them | default: 'Typical Products' }}</span>
      </div>

      {%- comment -%} Data rows {%- endcomment -%}
      {% for block in section.blocks %}
        {%- assign is_last = forloop.last -%}
        <div class="cell-us row-cell {% if is_last %}last-row{% endif %}" {{ block.shopify_attributes }}>
          <svg class="cell-icon icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm45.66,85.66-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32Z"/></svg>
          <span>{{ block.settings.us }}</span>
        </div>
        <div class="cell-them row-cell {% if is_last %}last-row{% endif %}">
          <svg class="cell-icon icon-cross" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm37.66,130.34a8,8,0,0,1-11.32,11.32L128,139.31l-26.34,26.35a8,8,0,0,1-11.32-11.32L116.69,128,90.34,101.66a8,8,0,0,1,11.32-11.32L128,116.69l26.34-26.35a8,8,0,0,1,11.32,11.32L139.31,128Z"/></svg>
          <span>{{ block.settings.them }}</span>
        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% render 'aliange-lp-scripts' %}

{% schema %}
{
  "name": "LP — Comparison",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow label", "default": "The Difference" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Why Aliangé Is Different" },
    { "type": "text", "id": "col_us", "label": "Left column header (Aliangé)", "default": "Aliangé Clinical Approach" },
    { "type": "text", "id": "col_them", "label": "Right column header (Competitor)", "default": "Typical Products" }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        { "type": "textarea", "id": "us", "label": "Aliangé (left)", "default": "Multi-pathway, synergistic protocol" },
        { "type": "textarea", "id": "them", "label": "Competitor (right)", "default": "Single ingredient focus" }
      ]
    }
  ],
  "presets": [{ "name": "LP — Comparison" }]
}
{% endschema %}
