{%- if section.settings.show_image == false or collection.image == blank and section.settings.image == blank -%}
  {%- assign show_image = false -%}
{%- else -%}
  {%- assign show_image = true -%}
{%- endif -%}

{%- capture collection_breadcrumb -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="breadcrumb breadcrumb--floating" aria-label="{{ 'general.breadcrumb.label' | t | escape }}">
      <ol class="breadcrumb__list unstyled-list">
        <li class="breadcrumb__list-item">
          <a href="{{ routes.root_url }}" class="smallcaps {% unless show_image %}link-faded{% endunless %}">{{ 'general.breadcrumb.home' | t }}</a>
        </li>

        <li class="breadcrumb__list-item">
          <a href="{{ routes.all_products_collection_url }}" class="smallcaps {% unless show_image %}link-faded{% endunless %}">{{ 'general.breadcrumb.shop' | t }}</a>
        </li>

        <li class="breadcrumb__list-item">
          <a href="{{ collection.url }}" aria-current="page" class="smallcaps {% unless show_image %}link-faded{% endunless %}">{{ collection.title }}</a>
        </li>
      </ol>
    </nav>
  {%- endif -%}
{%- endcapture -%}

{%- capture collection_content -%}
  {%- if section.settings.show_collection_title -%}
    <h1 class="h1">{{ collection.title }}</h1>
  {%- endif -%}

  {%- if section.settings.show_collection_description -%}
    <div class="collection-description">
      {%- liquid
        assign custom_description = collection.description
        case collection.handle
          when 'all'
            assign custom_description = "Welcome to the complete Aliangé clinical skincare range. Developed by Dr. Alison Jamieson, bringing over 40 years of dermatological expertise, every formulation in this collection is grounded in rigorous scientific evidence. We do not believe in superficial fixes; our products are designed to penetrate deeply, communicating with your cells to regenerate, repair, and fortify the skin matrix. From our frontier CellRevive Exosome Cream to our advanced peptide serums and intelligent exfoliants, each product serves a specific biological purpose. Whether you are building a complete anti-ageing protocol or seeking targeted treatments for pigmentation, redness, or dullness, you will find uncompromising, medical-grade efficacy here. Explore the full range below and experience the doctor-led difference."
          when 'protocols'
            assign custom_description = "At Aliangé, we do not believe in random skincare routines. We believe in Protocols. A protocol is a structured, medically-inspired system where every product is precisely calibrated to work in synergy with the next. Formulated by Dr. Alison Jamieson, our protocols eliminate the guesswork of mixing and matching different brands, which often leads to ingredient inactivation or barrier damage. Instead, our systems are designed in three distinct phases: Prepare & Purify, Stimulate & Communicate, and Protect & Fortify. Whether your primary concern is visible ageing, stubborn pigmentation, or persistent breakouts, choosing an Aliangé Protocol ensures you are delivering the correct molecular signals to your skin in the exact order required for profound, histological change. Find your targeted protocol below."
          when 'serums'
            assign custom_description = "Serums are the powerhouse of your skincare protocol. Formulated with smaller molecular weights, they are designed to bypass the surface layers of the skin and deliver highly concentrated active ingredients directly to the cellular matrix. The Aliangé serum collection features cutting-edge biotechnology, including DNA-repairing jellyfish peptides, barrier-fortifying sphingolipids, and potent brightening agents like Oligopeptide-68. Because our serums are clinically formulated, they provide targeted solutions for specific biological concerns—from stimulating collagen production and reducing the appearance of deep wrinkles to fading hyperpigmentation and balancing sebum production. Apply your chosen serum after cleansing and before your heavier creams to ensure maximum dermal penetration and transformative results."
          when 'masques'
            assign custom_description = "An Aliangé masque is an intensive, targeted treatment designed to accelerate your skin's recovery and fortification processes. Used two to three times a week, these highly concentrated formulations provide a vital boost to your daily protocol. Our collection features advanced biotechnology, including probiotic complexes that restore the skin's delicate microbiome and potent antioxidants that defend against environmental stressors like pollution and UV degradation. Whether you need to draw out impurities, calm inflammatory lesions, or deeply replenish moisture in compromised skin, our masques deliver immediate, visible revitalisation while supporting long-term barrier health. For optimal absorption, we recommend applying your masque following our Transforming Exfoliator."
          when 'cleanse'
            assign custom_description = "The foundation of any effective skincare protocol begins with intelligent preparation. The Aliangé Cleanse collection is formulated to purify the skin and remove cellular debris without ever stripping your natural lipid barrier. Traditional, harsh cleansers can cause micro-inflammation and disrupt the skin's acid mantle, rendering your expensive serums less effective. Our approach is different. Using gentle amino acids, coconut-derived surfactants, and precise blends of AHA and BHA exfoliants, our products prepare a perfectly balanced cellular canvas. By ensuring the skin is thoroughly cleansed and optimally exfoliated, you maximise the penetration and efficacy of every active ingredient that follows."
          when 'gift-cards'
            assign custom_description = "Give the gift of transformative, doctor-led skincare. An Aliangé digital gift card is the perfect way to introduce someone to the frontier of clinical skin regeneration. Whether they are looking to build a complete anti-ageing protocol, address specific concerns like pigmentation or dullness, or simply experience the luxury of our advanced formulations, a gift card allows them to choose the exact products their skin requires. Delivered instantly via email with simple instructions for redemption at checkout, our gift cards have no additional processing fees and offer the ultimate flexibility for the skincare enthusiast in your life."
        endcase
      -%}
      {{- custom_description -}}
    </div>
  {%- endif -%}
{%- endcapture -%}

{%- assign text_alignment = section.settings.text_alignment | replace: 'left', 'start' | replace: 'right', 'end' -%}

{%- if show_image -%}
  <style>
    #shopify-section-{{ section.id }} {
      --content-over-media-overlay: {{ section.settings.overlay_color.rgb }} / {{ section.settings.overlay_opacity | divided_by: 100.0 }};
      --content-over-media-content-max-width: var(--container-{{ section.settings.content_width }}-max-width);
    }
  </style>

  <collection-banner
    {% if section.settings.reveal %}
      reveal-on-scroll="true"
    {% endif %}
    class="collection-banner color-scheme color-scheme--{{ section.settings.color_scheme.id }}"
    {% if section.settings.allow_transparent_header %}
      allow-transparent-header
    {% endif %}
  >
    {%- unless section.settings.allow_transparent_header -%}
      {{- collection_breadcrumb -}}
    {%- endunless -%}

    <div class="content-over-media content-over-media--{{ section.settings.image_size }}">
      {%- capture picture_content -%}
        <picture>
          {%- if section.settings.mobile_image != blank -%}
            <source
                media="(max-width: 699px)"
                srcset="{{ section.settings.mobile_image | image_url: width: 400 }} 400w, {{ section.settings.mobile_image | image_url: width: 600 }} 600w, {{ section.settings.mobile_image | image_url: width: 800 }} 800w, {{ section.settings.mobile_image | image_url: width: 1000 }} 1000w"
                width="{{ section.settings.mobile_image.width }}"
                height="{{ section.settings.mobile_image.height }}"
            >
          {%- endif -%}

          {%- assign image = section.settings.image | default: collection.image -%}
          {{- image | image_url: width: image.width | image_tag: fetchpriority: 'high', widths: '300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200' -}}
        </picture>
      {%- endcapture -%}

      {%- if section.settings.enable_parallax -%}
        <image-parallax class="contents">
          {{- picture_content -}}
        </image-parallax>
      {%- else -%}
        {{- picture_content -}}
      {%- endif -%}

      <div class="prose place-self-center-{{ text_alignment }} text-{{ text_alignment }}">
        {{ collection_content }}
      </div>
    </div>
  </collection-banner>
{%- elsif collection_content != blank -%}
  <div class="color-scheme color-scheme--{{ section.settings.color_scheme.id }}">
    <div class="relative section-spacing section-spacing--tight">
      <div class="container container--{{ section.settings.content_width }} container--align-{{ text_alignment }}">
        {{- collection_breadcrumb -}}

        <div class="prose text-{{ text_alignment }}">
          {{- collection_content -}}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.collection_banner.name",
  "class": "shopify-section--collection-banner",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-4"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:global.image.image",
      "info": "t:sections.collection_banner.image_info"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "t:global.image.mobile_image",
      "info": "t:sections.collection_banner.mobile_image_info"
    },
    {
      "type": "select",
      "id": "image_size",
      "label": "t:global.image.size",
      "options": [
        {
          "value": "auto",
          "label": "t:global.sizes.original_image_ratio"
        },
        {
          "value": "xs",
          "label": "t:global.sizes.x_small"
        },
        {
          "value": "sm",
          "label": "t:global.sizes.small"
        },
        {
          "value": "md",
          "label": "t:global.sizes.medium"
        },
        {
          "value": "lg",
          "label": "t:global.sizes.large"
        }
      ],
      "info": "t:global.image.ratio_avoid_cropping_info",
      "default": "auto"
    },
    {
      "type": "checkbox",
      "id": "allow_transparent_header",
      "label": "t:global.section.allow_transparent_header",
      "info": "t:global.section.allow_transparent_header_info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:sections.collection_banner.show_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "reveal",
      "label": "t:sections.collection_banner.reveal",
      "default": true,
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "t:sections.collection_banner.enable_parallax",
      "info": "t:sections.collection_banner.enable_parallax_info",
      "default": true,
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "checkbox",
      "id": "show_collection_title",
      "label": "t:sections.collection_banner.show_collection_title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "label": "t:sections.collection_banner.show_collection_description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "t:sections.collection_banner.show_breadcrumb",
      "default": true
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "t:global.sizes.content_width",
      "options": [
        {
          "value": "xxs",
          "label": "t:global.sizes.xx_small"
        },
        {
          "value": "xs",
          "label": "t:global.sizes.x_small"
        },
        {
          "value": "sm",
          "label": "t:global.sizes.small"
        },
        {
          "value": "md",
          "label": "t:global.sizes.medium"
        },
        {
          "value": "lg",
          "label": "t:global.sizes.large"
        },
        {
          "value": "xl",
          "label": "t:global.sizes.x_large"
        }
      ],
      "default": "xs"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment",
      "label": "t:global.text.alignment",
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:global.colors.category",
      "info": "t:sections.collection_banner.colors_category_info"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:global.colors.overlay_color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:global.colors.overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 30
    }
  ]
}
{% endschema %}
