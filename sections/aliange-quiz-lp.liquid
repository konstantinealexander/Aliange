{%- comment -%}
  section: aliange-quiz-lp
  A dedicated SEO-optimized landing page section for the Aliangé skin quiz.
{%- endcomment -%}

<section class="quiz-lp section-spacing">
  <div class="container">
    <div class="quiz-lp__grid">
      <div class="quiz-lp__content">
        <span class="eyebrow">Professional Skin Assessment</span>
        <h1 class="h2">Find Your Doctor-Led Skincare Protocol</h1>
        <p class="lead">Stop guessing and start transforming. Our clinical assessment analysis your skin concerns—from pigmentation and sun damage to ageing—to recommend a medical-grade protocol designed for the Australian climate.</p>
        
        <ul class="quiz-lp__benefits">
          <li><strong>Clinical Expertise:</strong> Developed by Dr Alison Jamieson with 40+ years experience.</li>
          <li><strong>Concern-Based:</strong> Targeted solutions for your unique skin profile.</li>
          <li><strong>Evidence-Backed:</strong> Formulations that deliver visible results.</li>
        </ul>

        <div class="quiz-lp__actions">
          <a href="/pages/skin-quiz" class="button button--primary button--xl">Start Your Assessment</a>
        </div>
      </div>

      <div class="quiz-lp__image">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="Professional Skincare Assessment" loading="lazy">
        {%- else -%}
          <div class="placeholder-overlay">
            <span class="placeholder-text">Dr Jamieson's Clinical Protocol</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quiz Landing Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    }
  ],
  "presets": [
    {
      "name": "Quiz Landing Page"
    }
  ]
}
{% endschema %}

<style>
  .quiz-lp {
    padding: 100px 0;
    background: #fff;
  }
  .quiz-lp__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .eyebrow {
    display: block;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.8em;
    color: #b89e8a;
    margin-bottom: 20px;
    font-weight: 600;
  }
  .quiz-lp__content h1 {
    margin-bottom: 24px;
    line-height: 1.1;
  }
  .lead {
    font-size: 1.2em;
    color: #444;
    margin-bottom: 30px;
    line-height: 1.6;
  }
  .quiz-lp__benefits {
    list-style: none;
    padding: 0;
    margin: 0 0 40px 0;
  }
  .quiz-lp__benefits li {
    margin-bottom: 15px;
    position: relative;
    padding-left: 30px;
  }
  .quiz-lp__benefits li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #27ae60;
    font-weight: bold;
  }
  .quiz-lp__image img {
    width: 100%;
    border-radius: 12px;
    box-shadow: 20px 20px 0 #f5f0eb;
  }
  .placeholder-overlay {
    background: #f5f0eb;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
  }
  .placeholder-text {
    color: #b89e8a;
    font-weight: 600;
    font-size: 1.5em;
  }
  .button--xl {
    padding: 20px 40px;
    font-size: 1.1em;
  }

  @media (max-width: 768px) {
    .quiz-lp__grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .quiz-lp__benefits li {
      text-align: left;
    }
    .quiz-lp__image {
      order: -1;
    }
  }
</style>
