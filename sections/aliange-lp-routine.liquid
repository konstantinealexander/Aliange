
{%- style -%}
  #lp-protocol-{{ section.id }} { background-color: var(--lp-bg-muted); }
  #lp-protocol-{{ section.id }} .lp-protocol-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--lp-space-2xl);
  }
  #lp-protocol-{{ section.id }} .lp-protocol-steps {
    display: flex;
    flex-direction: column;
    gap: var(--lp-space-md);
  }
  #lp-protocol-{{ section.id }} .lp-protocol-step {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--lp-space-lg);
    align-items: start;
    background-color: var(--lp-bg);
    border: 1px solid var(--lp-border);
    border-radius: var(--lp-radius-lg);
    padding: var(--lp-space-xl);
  }
  @media (min-width: 768px) {
    #lp-protocol-{{ section.id }} .lp-protocol-step {
      grid-template-columns: 56px 1fr auto;
      align-items: center;
    }
  }
  #lp-protocol-{{ section.id }} .lp-protocol-num {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: var(--lp-ink);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--lp-font-heading);
    font-size: 18px;
    font-weight: 600;
    flex-shrink: 0;
  }
  #lp-protocol-{{ section.id }} .lp-protocol-thumb {
    width: 48px;
    height: 48px;
    border-radius: var(--lp-radius-md);
    overflow: hidden;
    flex-shrink: 0;
  }
  #lp-protocol-{{ section.id }} .lp-protocol-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (min-width: 768px) {
    #lp-protocol-{{ section.id }} .lp-protocol-thumb { width: 56px; height: 56px; }
  }
  #lp-protocol-{{ section.id }} .lp-protocol-body { flex: 1; }
  #lp-protocol-{{ section.id }} .lp-protocol-name {
    font-family: var(--lp-font-heading);
    font-size: clamp(1rem, 1.8vw, 1.3rem);
    font-weight: 600;
    color: var(--lp-ink);
    margin: 0 0 4px;
  }
  #lp-protocol-{{ section.id }} .lp-protocol-why {
    font-family: var(--lp-font-body);
    font-size: 14px;
    color: var(--lp-body);
    line-height: 1.6;
    margin: 0 0 var(--lp-space-sm);
  }
  #lp-protocol-{{ section.id }} .lp-protocol-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  #lp-protocol-{{ section.id }} .lp-protocol-tag {
    display: inline-block;
    padding: 3px 10px;
    background-color: var(--lp-bg-muted);
    border-radius: 20px;
    font-family: var(--lp-font-body);
    font-size: 12px;
    font-weight: 600;
    color: var(--lp-body);
    letter-spacing: 0.03em;
  }
  #lp-protocol-{{ section.id }} .lp-protocol-price {
    font-family: var(--lp-font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--lp-ink);
    white-space: nowrap;
    margin-top: var(--lp-space-sm);
  }
  @media (min-width: 768px) {
    #lp-protocol-{{ section.id }} .lp-protocol-price { margin-top: 0; text-align: right; }
  }
  #lp-protocol-{{ section.id }} .lp-protocol-cta {
    text-align: center;
    margin-top: var(--lp-space-2xl);
  }
{%- endstyle -%}

<section id="lp-protocol-{{ section.id }}" class="lp-section">
  <div class="lp-container">
    <div class="lp-protocol-header lp-reveal">
      {%- if section.settings.label != blank -%}
        <span class="lp-section-label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="lp-heading-lg">{{ section.settings.headline }}</h2>
      {%- if section.settings.subheadline != blank -%}
        <p class="lp-body-text">{{ section.settings.subheadline }}</p>
      {%- endif -%}
    </div>

    <div class="lp-protocol-steps">
      {%- for block in section.blocks -%}
        <div class="lp-protocol-step lp-reveal" {{ block.shopify_attributes }}>
          {%- if block.settings.image -%}
            <div class="lp-protocol-thumb">
              <img
                src="{{ block.settings.image | image_url: width: 112 }}"
                alt="{{ block.settings.image.alt | default: block.settings.name | escape }}"
                width="56"
                height="56"
                loading="lazy"
              >
            </div>
          {%- elsif block.settings.image_path != blank -%}
            <div class="lp-protocol-thumb">
              <img
                src="{{ block.settings.image_path | asset_url }}"
                alt="{{ block.settings.name | escape }}"
                width="56"
                height="56"
                loading="lazy"
              >
            </div>
          {%- else -%}
            <div class="lp-protocol-num" aria-hidden="true">{{ forloop.index }}</div>
          {%- endif -%}
          <div class="lp-protocol-body">
            <h3 class="lp-protocol-name">{{ block.settings.name }}</h3>
            {%- if block.settings.why != blank -%}
              <p class="lp-protocol-why">{{ block.settings.why }}</p>
            {%- endif -%}
            <div class="lp-protocol-meta">
              {%- if block.settings.key_active != blank -%}
                <span class="lp-protocol-tag">Key active: {{ block.settings.key_active }}</span>
              {%- endif -%}
              {%- if block.settings.step != blank -%}
                <span class="lp-protocol-tag">{{ block.settings.step }}</span>
              {%- endif -%}
            </div>
          </div>
          {%- if block.settings.price != blank -%}
            <div class="lp-protocol-price">{{ block.settings.price }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_text != blank -%}
      <div class="lp-protocol-cta lp-reveal">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="lp-btn">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% render 'aliange-lp-scripts' %}

{% schema %}
{
  "name": "LP — Protocol",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow label", "default": "The Protocol" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Your Recommended Protocol" },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Shop the Protocol" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "blocks": [
    {
      "type": "product_step",
      "name": "Product Step",
      "settings": [
        { "type": "text", "id": "name", "label": "Product name", "default": "Jellyfish Peptide X Serum" },
        { "type": "text", "id": "price", "label": "Price", "default": "$225" },
        { "type": "textarea", "id": "why", "label": "Why it's recommended" },
        { "type": "text", "id": "key_active", "label": "Key active ingredient" },
        { "type": "text", "id": "step", "label": "Step / timing", "default": "AM & PM" },
        { "type": "image_picker", "id": "image", "label": "Product image (upload)" },
        { "type": "text", "id": "image_path", "label": "Product image asset filename (e.g. sku-day-cream-spf15.png)" }
      ]
    }
  ],
  "presets": [{ "name": "LP — Protocol" }]
}
{% endschema %}
