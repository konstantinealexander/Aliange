<script>
(function() {
  function init() {
    // ── Scroll Reveal ──────────────────────────────────────────
    if ('IntersectionObserver' in window) {
      var revealObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.lp-reveal').forEach(function(el) {
        revealObserver.observe(el);
      });
    } else {
      document.querySelectorAll('.lp-reveal').forEach(function(el) {
        el.classList.add('is-visible');
      });
    }

    // ── Accordion (FAQ) ────────────────────────────────────────
    document.querySelectorAll('[data-lp-accordion]').forEach(function(accordion) {
      accordion.querySelectorAll('[data-lp-accordion-trigger]').forEach(function(trigger) {
        trigger.addEventListener('click', function() {
          var item = trigger.closest('[data-lp-accordion-item]');
          var content = item.querySelector('[data-lp-accordion-content]');
          var isOpen = item.classList.contains('is-open');

          // Close all sibling items
          accordion.querySelectorAll('[data-lp-accordion-item].is-open').forEach(function(openItem) {
            openItem.classList.remove('is-open');
            openItem.querySelector('[data-lp-accordion-content]').style.maxHeight = '0';
            openItem.querySelector('[data-lp-accordion-trigger]').setAttribute('aria-expanded', 'false');
          });

          if (!isOpen) {
            item.classList.add('is-open');
            content.style.maxHeight = content.scrollHeight + 'px';
            trigger.setAttribute('aria-expanded', 'true');
          }
        });

        trigger.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); trigger.click(); }
        });
      });
    });

    // ── Stat Counter ───────────────────────────────────────────
    if ('IntersectionObserver' in window) {
      var statObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          statObserver.unobserve(entry.target);
          var el = entry.target;
          var raw = el.dataset.statTarget || el.textContent;
          var numeric = parseFloat(raw.replace(/[^0-9.]/g, ''));
          var prefix = raw.match(/^[^0-9]*/)[0];
          var suffix = raw.replace(/^[^0-9]*[0-9.,]+/, '');
          if (isNaN(numeric)) return;
          var start = 0;
          var duration = 1400;
          var startTime = null;
          function ease(t) { return 1 - Math.pow(1 - t, 3); }
          function step(ts) {
            if (!startTime) startTime = ts;
            var progress = Math.min((ts - startTime) / duration, 1);
            var val = start + (numeric - start) * ease(progress);
            el.textContent = prefix + (Number.isInteger(numeric) ? Math.round(val) : val.toFixed(1)) + suffix;
            if (progress < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        });
      }, { threshold: 0.5 });

      document.querySelectorAll('[data-lp-stat]').forEach(function(el) {
        el.dataset.statTarget = el.textContent;
        statObserver.observe(el);
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('shopify:section:load', init);
})();
</script>
