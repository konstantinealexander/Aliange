{%- comment -%}
  snippet: seo-meta-tags
  Centralized SEO logic for titles and meta descriptions.
{%- endcomment -%}

{%- liquid
  assign seo_title = page_title
  assign seo_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'index'
    assign seo_title = 'Aliangé — Doctor-Led Skincare Protocols | Australian Made'
    assign seo_description = 'Doctor-formulated skincare protocols that deliver histological skin change. Shop the Aliangé clinical range — Australian made.'
  elsif request.page_type == 'product'
    assign seo_benefit = product.metafields.custom.seo_benefit
    if seo_benefit != blank
      assign seo_title = product.title | append: ' — ' | append: seo_benefit | append: ' | Aliangé'
      assign seo_description = seo_benefit
    else
      assign seo_title = product.title | append: ' | Aliangé'
      assign seo_description = product.description | strip_html | truncate: 155
    endif
  elsif request.page_type == 'collection'
    assign seo_title = collection.title | append: ' — Medical-Grade Skincare Australia | Aliangé'
    case collection.handle
      when 'all'
        assign seo_description = 'Shop the complete range of Aliangé clinical skincare. Formulated by Dr. Alison Jamieson, our evidence-based products are designed to regenerate and protect.'
      when 'protocols'
        assign seo_description = 'Discover Aliangé Skincare Protocols. Clinically designed systems that work synergistically to target ageing, pigmentation, breakouts, and more.'
      when 'serums'
        assign seo_description = 'Shop Aliangé clinical serums. Highly concentrated formulas featuring exosomes, peptides, and niacinamide to target cellular repair and hydration.'
      when 'masques'
        assign seo_description = 'Elevate your routine with Aliangé clinical masques. Probiotic and anti-pollutant treatments designed to purify, balance, and deeply hydrate your skin.'
      when 'cleanse'
        assign seo_description = 'Prepare your skin with Aliangé cleansers and exfoliators. Gentle, effective formulas that purify the skin without disrupting the delicate lipid barrier.'
      when 'gift-cards'
        assign seo_description = 'Give the gift of clinical skincare with an Aliangé digital gift card. The perfect present for those seeking doctor-led, evidence-based skin regeneration.'
    endcase
  elsif request.page_type == 'article'
    assign seo_title = article.title | append: ' | Aliangé'
  elsif request.page_type == 'page'
    case page.handle
      when 'quiz'
        assign seo_title = 'Skincare Quiz — Find Your Perfect Routine | Aliangé'
        assign seo_description = 'Not sure where to start? Take the Aliangé skincare quiz to find your personalised clinical protocol. Doctor-led recommendations for your skin type and concerns.'
      when 'concern-aging'
        assign seo_description = 'Doctor-led guide to skin ageing — collagen loss, photoageing, and the Aliangé anti-ageing protocol for firmer, rejuvenated skin. Australian made.'
      when 'concern-pigmentation'
        assign seo_description = 'Clinical guide to hyperpigmentation and dark spots. How Aliangé Oligopeptide-68, Vitamin C, and multi-acid actives correct uneven skin tone in Australia.'
      when 'concern-redness'
        assign seo_description = 'Doctor-led guide to persistent redness and sensitive skin. How Aliangé barrier-repair formulations reduce inflammation and rebuild skin resilience.'
      when 'concern-breakouts'
        assign seo_description = 'Clinical guide to acne and congested skin. How the Aliangé doctor-led protocol clears pores, reduces inflammation and prevents recurrence.'
      when 'concern-dullness'
        assign seo_description = 'The cellular causes of dull, fatigued skin — impaired turnover, dehydration, oxidative stress — and how Aliangé brightening protocols restore radiance.'
      when 'best-skincare-women-over-40-australia'
        assign seo_description = 'Doctor-led guide to skincare after 40 — hormonal changes, collagen loss, barrier thinning. Evidence-based Aliangé protocols for women in Australia.'
      when 'skincare-protocol-vs-routine'
        assign seo_description = 'What is the difference between a skincare routine and a protocol? Why doctor-sequenced clinical protocols produce real, histological skin change.'
      when 'educate-exosome'
        assign seo_description = 'The science of exosomes in skincare — how cellular communication drives skin renewal, and how the Aliangé CellRevive Exosome Cream works.'
      when 'educate-peptide'
        assign seo_description = 'The science of peptides in skincare — signal, carrier, and neurotransmitter peptides explained. Discover the Aliangé Jellyfish Peptide X Serum.'
      when 'pillar-sunshine-coast'
        assign seo_description = 'Aliangé skincare for Sunshine Coast conditions — doctor-developed protocols formulated for Queensland UV intensity, humidity, and subtropical sun damage.'
      when 'pillar-queensland'
        assign seo_description = 'Doctor-led skincare for Queensland conditions — high UV, humidity, and subtropical sun damage. Aliangé protocols formulated for Australian skin.'
      when 'how-to-use'
        assign seo_description = 'Step-by-step guide to applying Aliangé products in the correct protocol order — Prepare and Purify, Stimulate and Communicate, Protect and Fortify.'
      when 'ingredient-glossary'
        assign seo_description = 'Complete Aliangé ingredient glossary — scientific explanations of exosomes, peptides, niacinamide, retinol, and every active in the clinical range.'
    endcase
  endif
-%}

<title>{{ seo_title | strip_newlines | strip }}</title>

{%- if seo_description -%}
  <meta name="description" content="{{ seo_description | escape }}">
{%- endif -%}
